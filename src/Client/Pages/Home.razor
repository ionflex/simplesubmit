@page "/"
@inject SuggestionsApi Api

<PageTitle>SimpleSubmit</PageTitle>

<h1>Suggestions</h1>

<EditForm Model="form" OnValidSubmit="SubmitAsync" FormName="submit-suggestion">
    <div class="mb-2">
        <label for="text" class="form-label">Suggestion</label>
        <textarea id="text" class="form-control" rows="3" maxlength="500"
                  @bind="form.Text" @bind:event="oninput" disabled="@busy"></textarea>
        <div class="form-text">@(form.Text?.Length ?? 0) / 500</div>
    </div>
    <div class="mb-2">
        <label for="author" class="form-label">Name (optional)</label>
        <input id="author" class="form-control" maxlength="60"
               @bind="form.AuthorName" disabled="@busy" />
    </div>
    <button type="submit" class="btn btn-primary" disabled="@(busy || string.IsNullOrWhiteSpace(form.Text))">
        @(busy ? "Submitting..." : "Submit")
    </button>
</EditForm>

@if (error is not null)
{
    <div class="alert alert-danger mt-3" role="alert">@error</div>
}

<hr />

@if (items is null)
{
    <p><em>Loading...</em></p>
}
else if (items.Count == 0)
{
    <p><em>No suggestions yet. Be the first.</em></p>
}
else
{
    <div class="d-flex justify-content-end mb-2">
        <div class="btn-group btn-group-sm" role="group" aria-label="Sort order">
            <button type="button"
                    class="btn @(sort == Sort.Votes ? "btn-secondary" : "btn-outline-secondary")"
                    @onclick="() => sort = Sort.Votes">
                Top voted
            </button>
            <button type="button"
                    class="btn @(sort == Sort.Newest ? "btn-secondary" : "btn-outline-secondary")"
                    @onclick="() => sort = Sort.Newest">
                Newest
            </button>
        </div>
    </div>

    <ul class="list-group">
        @foreach (var item in Sorted(items))
        {
            <li class="list-group-item d-flex justify-content-between align-items-start">
                <div class="me-3">
                    <div>@item.Text</div>
                    <small class="text-muted">
                        @(item.AuthorName ?? "anonymous") · @item.SubmittedAtUtc.ToLocalTime().ToString("g")
                    </small>
                </div>
                <button class="btn @(item.HasVoted ? "btn-primary" : "btn-outline-primary") btn-sm"
                        disabled="@busy"
                        title="@(item.HasVoted ? "Remove your vote" : "Vote for this")"
                        @onclick="() => ToggleVoteAsync(item)">
                    @(item.HasVoted ? "Voted" : "Vote") · @item.VoteCount
                </button>
            </li>
        }
    </ul>
}

@code {
    private enum Sort { Votes, Newest }

    private sealed class Form
    {
        public string Text { get; set; } = "";
        public string? AuthorName { get; set; }
    }

    private readonly Form form = new();
    private IReadOnlyList<SuggestionListItem>? items;
    private Sort sort = Sort.Votes;
    private bool busy;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private IEnumerable<SuggestionListItem> Sorted(IReadOnlyList<SuggestionListItem> source) => sort switch
    {
        Sort.Newest => source.OrderByDescending(i => i.SubmittedAtUtc),
        _ => source
            .OrderByDescending(i => i.VoteCount)
            .ThenByDescending(i => i.SubmittedAtUtc),
    };

    private async Task SubmitAsync()
    {
        busy = true;
        error = null;
        try
        {
            await Api.SubmitAsync(new SubmitSuggestionRequest(form.Text, form.AuthorName));
            form.Text = "";
            form.AuthorName = null;
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private async Task ToggleVoteAsync(SuggestionListItem item)
    {
        busy = true;
        error = null;
        try
        {
            var response = await Api.VoteAsync(item.Id, voted: !item.HasVoted);
            if (response is not null && items is not null)
            {
                items = items
                    .Select(i => i.Id == item.Id
                        ? i with { HasVoted = response.HasVoted, VoteCount = response.VoteCount }
                        : i)
                    .ToArray();
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private async Task RefreshAsync()
    {
        try
        {
            items = await Api.ListAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
            items = [];
        }
    }
}
