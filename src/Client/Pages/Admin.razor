@page "/admin"
@inject AdminApi Api

<PageTitle>SimpleSubmit · Admin</PageTitle>

<h1>Admin</h1>

@switch (state)
{
    case State.Loading:
        <p><em>Loading...</em></p>
        break;

    case State.NotSignedIn:
        <div class="alert alert-warning">
            You need to sign in.
            <div class="mt-2">
                <a class="btn btn-primary btn-sm me-2" href="/.auth/login/github?post_login_redirect_uri=/admin">Sign in with GitHub</a>
                <a class="btn btn-primary btn-sm" href="/.auth/login/aad?post_login_redirect_uri=/admin">Sign in with Microsoft</a>
            </div>
        </div>
        break;

    case State.NoRequest:
        <div class="alert alert-info">
            Signed in as <strong>@(self?.DisplayName ?? "unknown")</strong> (@self?.IdentityProvider).
            You are not an admin.
            <div class="mt-2">
                <button class="btn btn-primary btn-sm" disabled="@busy" @onclick="RequestAccessAsync">Request admin access</button>
                <a class="btn btn-outline-secondary btn-sm ms-2" href="/.auth/logout">Sign out</a>
            </div>
        </div>
        break;

    case State.Pending:
        <div class="alert alert-info">
            Your admin-access request is pending approval.
            <a class="btn btn-outline-secondary btn-sm ms-2" href="/.auth/logout">Sign out</a>
        </div>
        break;

    case State.Admin:
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span>Signed in as <strong>@(self?.DisplayName ?? "unknown")</strong> (@self?.IdentityProvider)</span>
            <div>
                <a class="btn btn-outline-primary btn-sm me-2" href="/admin/submissions">Manage submissions</a>
                <a class="btn btn-outline-secondary btn-sm" href="/.auth/logout">Sign out</a>
            </div>
        </div>

        <h2>Moderation</h2>
        <p class="text-muted">@pending.Count pending</p>
        @if (pending.Count == 0)
        {
            <p><em>Nothing to moderate.</em></p>
        }
        else
        {
            <ul class="list-group mb-4">
                @foreach (var item in pending)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-start">
                        <div class="me-3">
                            <div>@item.Text</div>
                            <small class="text-muted">
                                @(item.AuthorName ?? "anonymous") · @item.SubmittedAtUtc.ToLocalTime().ToString("g")
                            </small>
                        </div>
                        <div class="btn-group btn-group-sm" role="group">
                            <button class="btn btn-success" disabled="@busy" @onclick="() => ApproveSuggestionAsync(item.Id)">Approve</button>
                            <button class="btn btn-danger" disabled="@busy" @onclick="() => RejectSuggestionAsync(item.Id)">Reject</button>
                        </div>
                    </li>
                }
            </ul>
        }

        <h2>Admins</h2>
        @if (admins.Count == 0)
        {
            <p><em>No admins yet.</em></p>
        }
        else
        {
            <ul class="list-group mb-4">
                @foreach (var a in admins)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-start">
                        <div class="me-3">
                            <div>
                                <strong>@a.DisplayName</strong>
                                @if (a.IsBootstrap)
                                {
                                    <span class="badge bg-secondary ms-1">bootstrap</span>
                                }
                                else if (a.Status == AdminStatus.Pending)
                                {
                                    <span class="badge bg-warning text-dark ms-1">pending</span>
                                }
                                else
                                {
                                    <span class="badge bg-success ms-1">active</span>
                                }
                            </div>
                            <small class="text-muted font-monospace">@a.IdentityProvider · @a.PrincipalId</small>
                        </div>
                        <div class="btn-group btn-group-sm" role="group">
                            @if (!a.IsBootstrap && a.Status == AdminStatus.Pending)
                            {
                                <button class="btn btn-success" disabled="@busy" @onclick="() => ApproveAdminAsync(a.PrincipalId)">Approve</button>
                            }
                            @if (!a.IsBootstrap)
                            {
                                <button class="btn btn-outline-danger" disabled="@busy" @onclick="() => RemoveAdminAsync(a.PrincipalId)">Remove</button>
                            }
                        </div>
                    </li>
                }
            </ul>
        }

        <h2>Purge rejected</h2>
        <p class="text-muted small">Deletes rejected suggestions older than the given number of days.</p>
        <div class="input-group mb-2" style="max-width: 320px;">
            <span class="input-group-text">Older than</span>
            <input type="number" class="form-control" min="0" @bind="purgeDays" disabled="@busy" />
            <span class="input-group-text">days</span>
        </div>
        <button class="btn btn-outline-danger" disabled="@busy" @onclick="PurgeAsync">Purge rejected</button>

        @if (lastPurgeCount is not null)
        {
            <div class="alert alert-info mt-3">Purged @lastPurgeCount rejected suggestion(s).</div>
        }
        break;
}

@if (error is not null)
{
    <div class="alert alert-danger mt-3">@error</div>
}

@code {
    private enum State { Loading, NotSignedIn, NoRequest, Pending, Admin }

    private State state = State.Loading;
    private AdminSelfStatus? self;
    private IReadOnlyList<Suggestion> pending = [];
    private IReadOnlyList<AdminEntry> admins = [];
    private bool busy;
    private int purgeDays = 30;
    private int? lastPurgeCount;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        error = null;
        state = State.Loading;
        try
        {
            self = await Api.GetSelfAsync();
            state = ResolveState(self);
            if (state == State.Admin)
            {
                await LoadAdminDataAsync();
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private static State ResolveState(AdminSelfStatus status)
    {
        if (!status.IsSignedIn) return State.NotSignedIn;
        if (status.IsAdmin) return State.Admin;
        return status.RequestStatus == AdminStatus.Pending ? State.Pending : State.NoRequest;
    }

    private async Task LoadAdminDataAsync()
    {
        var (_, items) = await Api.ListPendingAsync();
        pending = items;
        admins = await Api.ListAdminsAsync();
    }

    private async Task RequestAccessAsync()
    {
        busy = true;
        try
        {
            await Api.RequestAccessAsync();
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private async Task ApproveSuggestionAsync(Guid id)
    {
        await RunAsync(async () =>
        {
            await Api.ApproveSuggestionAsync(id);
            await LoadAdminDataAsync();
        });
    }

    private async Task RejectSuggestionAsync(Guid id)
    {
        await RunAsync(async () =>
        {
            await Api.RejectSuggestionAsync(id);
            await LoadAdminDataAsync();
        });
    }

    private async Task ApproveAdminAsync(string principalId)
    {
        await RunAsync(async () =>
        {
            await Api.ApproveAdminAsync(principalId);
            admins = await Api.ListAdminsAsync();
        });
    }

    private async Task RemoveAdminAsync(string principalId)
    {
        await RunAsync(async () =>
        {
            await Api.RemoveAdminAsync(principalId);
            admins = await Api.ListAdminsAsync();
        });
    }

    private async Task PurgeAsync()
    {
        busy = true;
        lastPurgeCount = null;
        error = null;
        try
        {
            lastPurgeCount = await Api.PurgeRejectedAsync(purgeDays);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private async Task RunAsync(Func<Task> action)
    {
        busy = true;
        error = null;
        try
        {
            await action();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }
}
